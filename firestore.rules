rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "nxnayeem000@gmail.com" || 
        request.auth.token.email == "admin@solesphere.com"
      ); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- VALIDATION BLUEPRINTS ---
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'brand', 'price', 'category']) &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
        data.brand is string && data.brand.size() > 0 &&
        data.price is number && data.price >= 0 &&
        data.category is string &&
        (!('discount' in data) || (data.discount is number && data.discount >= 0 && data.discount <= 100)) &&
        (!('stock' in data) || (data.stock is number && data.stock >= 0));
    }

    function isValidOrder(data) {
      let requiredKeys = ['customerName', 'email', 'phone', 'address', 'paymentMethod', 'total', 'items', 'status', 'date'];
      return data.keys().hasAll(requiredKeys) &&
        data.customerName is string && data.customerName.size() > 0 &&
        data.email is string && data.email.size() > 0 &&
        data.phone is string && data.phone.size() >= 5 &&
        data.address is string && data.address.size() > 0 &&
        data.paymentMethod is string &&
        data.total is number && data.total >= 0 &&
        data.items is list && data.items.size() > 0 &&
        data.status in ['Processing', 'Shipped', 'Delivered', 'Cancelled'] &&
        data.date is string;
    }

    // --- COLLECTION RULES ---

    // Products
    match /products/{productId} {
      allow read: if true; // Public catalog
      allow write: if isAdmin() && isValidProduct(incoming());
    }

    // Orders
    match /orders/{orderId} {
      // TRACKING: Allow public get so customers can track without login if they have the ID
      allow get: if true;
      
      // ADMIN: Only admins can list all orders
      allow list: if isAdmin();
      
      // CREATE: Allow creation (guest or logged-in)
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      
      // UPDATE: Only admins can update status or other fields
      allow update: if isAdmin() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
      
      allow delete: if isAdmin();
    }
  }
}
