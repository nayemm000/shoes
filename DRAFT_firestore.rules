rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Only allow admin operations (in this app, we'll assume admin check via a special flag or just restricted paths)
    // For simplicity, we'll use a placeholder for admin check if needed, but the current app uses client-side admin flag.
    // We should harden this by checking a role in a user collection if we had one.
    // Since we don't have a 'users' collection with roles yet, we'll focus on data integrity.
    
    // --- Products ---
    match /products/{productId} {
      function isValidProduct(data) {
        return data.keys().hasAll(['name', 'brand', 'price']) &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
               data.brand is string && data.brand.size() > 0 && data.brand.size() <= 100 &&
               data.price is number && data.price >= 0 &&
               (!('discount' in data) || (data.discount is number && data.discount >= 0 && data.discount <= 100)) &&
               (!('rating' in data) || (data.rating is number && data.rating >= 0 && data.rating <= 5)) &&
               (!('stock' in data) || (data.stock is number && data.stock >= 0));
      }

      allow read: if true; // Public catalog
      
      allow create: if isSignedIn() && isValidId(productId) && isValidProduct(incoming());
      
      allow update: if isSignedIn() && isValidProduct(incoming()) && (
        // Allow updating stock, price, etc.
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'brand', 'price', 'discount', 'category', 'sizes', 'stock', 
          'images', 'description', 'rating', 'reviews', 'variants', 'updatedAt'
        ])
      );
      
      allow delete: if isSignedIn();
    }

    // --- Orders ---
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.keys().hasAll(['customerName', 'phone', 'address', 'total', 'items', 'status', 'date']) &&
               data.customerName is string && data.customerName.size() > 0 &&
               data.phone is string && data.phone.size() >= 5 &&
               data.address is string && data.address.size() > 0 &&
               data.total is number && data.total >= 0 &&
               data.items is list && data.items.size() > 0 &&
               data.status in ['Processing', 'Shipped', 'Delivered', 'Cancelled'] &&
               data.date is string;
      }

      // Read: Users can read their own order if they know the ID (Tracking)
      allow get: if true; 
      allow list: if false; // Deny blanket listing of orders to prevent scraping

      allow create: if isValidId(orderId) && isValidOrder(incoming());
      
      allow update: if isSignedIn() && isValidOrder(incoming()) && (
        // Action: Update Status
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && 
         existing().status != 'Delivered' && existing().status != 'Cancelled')
      );

      allow delete: if isSignedIn();
    }
  }
}
